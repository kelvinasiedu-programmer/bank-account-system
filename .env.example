# Persistence
STORAGE_PATH=data/accounts.json

# Tiered interest rates
TIER_1_LIMIT=1000.0
TIER_1_RATE=0.03
TIER_2_LIMIT=5000.0
TIER_2_RATE=0.05
TIER_3_RATE=0.07

# Checking account
OVERDRAFT_LIMIT=-500.0
OVERDRAFT_FEE=25.0

# Rate limiting
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# CORS: comma-free list is not supported by pydantic here; use a JSON array in
# the environment, e.g. CORS_ORIGINS=["https://app.example.com"]. Leave unset
# for the "*" default (which disables credentialed cross-origin requests).

# Auth: required by the destructive DELETE endpoints. Unset means those
# endpoints return 503. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=
